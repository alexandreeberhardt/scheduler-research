4      10    60     -5    0.40   CFS     0    200   gstreamer
5      20    150    0     0.25   CFS     0    0     postgres
6      2     30     0     0.00   FIFO    80   0     kworker
7      30    200    -10   0.15   CFS     0    0     Xorg
8      50    100    5     0.50   CFS     0    0     firefox
9      15    250    0     0.20   CFS     0    0     python3
